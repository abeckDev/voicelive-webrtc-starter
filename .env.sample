# .env.sample
# -----------
# Copy this file to .env and fill in your values.
# The .env file must NOT be committed to source control.

# ── Required ──────────────────────────────────────────────────────────────

# Azure AI Services endpoint (required)
# Create an Azure AI Services resource with Voice Live enabled.
# After deploying infra/main.bicep, copy the 'endpoint' output here.
AZURE_VOICELIVE_ENDPOINT=https://your-ai-services.cognitiveservices.azure.com/

# ── Authentication ────────────────────────────────────────────────────────

# API key for local development.
# Leave empty to authenticate via 'az login' or Managed Identity in production.
# Get the key with:
#   az cognitiveservices account keys list --name <account> --resource-group <rg> --query key1 -o tsv
AZURE_VOICELIVE_API_KEY=

# ── Azure OpenAI (extraction agent) ──────────────────────────────────────

# Azure OpenAI endpoint for the GPT-4o extraction agent.
# Defaults to AZURE_VOICELIVE_ENDPOINT if not set (they share the same resource).
AZURE_OPENAI_ENDPOINT=

# GPT-4o deployment name in your Azure OpenAI / AI Services resource.
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Voice Live model settings ─────────────────────────────────────────────

# Voice Live model (the language model powering the voice session).
VOICELIVE_MODEL=gpt-4o

# Azure Neural TTS voice for the assistant's spoken responses.
# See: https://learn.microsoft.com/azure/ai-services/speech-service/language-support
VOICELIVE_VOICE=en-US-JennyNeural
