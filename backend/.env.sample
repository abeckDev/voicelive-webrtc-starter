# backend/.env.sample
# Copy this file to .env and fill in your values.
# This file is identical to the root .env.sample for convenience.

# Azure AI Services endpoint (required)
# Create an Azure AI Services resource with Voice Live enabled
AZURE_VOICELIVE_ENDPOINT=https://your-ai-services.cognitiveservices.azure.com/

# API key for local development (leave empty to use az login / Managed Identity)
AZURE_VOICELIVE_API_KEY=

# Azure OpenAI endpoint for the extraction agent
# Defaults to AZURE_VOICELIVE_ENDPOINT if not set
AZURE_OPENAI_ENDPOINT=

# GPT-4o deployment name in your Azure OpenAI resource
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Voice Live model (default: gpt-4o)
VOICELIVE_MODEL=gpt-4o

# Azure Neural TTS voice
VOICELIVE_VOICE=en-US-JennyNeural

# Azure Blob Storage (for Save to Blob export)
# AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
# AZURE_STORAGE_CONTAINER_NAME=protocols
